# ── Server ──────────────────────────────────────
DEBUG=false

# ── Supabase（免費）https://supabase.com ────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ── Upstash Redis（免費）https://upstash.com ────
REDIS_URL=rediss://default:token@your-endpoint.upstash.io:6379

# ── Gemini AI（免費）https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# ── Groq（免費 fallback）https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# ── FinMind（免費）https://finmindtrade.com ─────
FINMIND_TOKEN=your-finmind-token

# ── CORS ────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
