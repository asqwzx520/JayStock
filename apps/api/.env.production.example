# ── StockPulse API — 生產環境設定範本 ─────────────────────────────────────────
# 複製為 .env 並填入真實值，切勿提交 .env 至版本控制

# === Server ===
DEBUG=false
CORS_ORIGINS=["https://stockpulse.tw","https://www.stockpulse.tw"]

# === Supabase (PostgreSQL + Auth) ===
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Upstash Redis ===
REDIS_URL=rediss://:<password>@<host>.upstash.io:6379

# === AI Services ===
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# === FinMind Data Token ===
FINMIND_TOKEN=your_finmind_token

# === Email Digest (SMTP) ===
# Gmail: 需開啟 2FA 並建立「應用程式密碼」
DIGEST_SMTP_HOST=smtp.gmail.com
DIGEST_SMTP_PORT=587
DIGEST_SMTP_USER=your@gmail.com
DIGEST_SMTP_PASS=xxxx xxxx xxxx xxxx
# 逗號分隔的收件人清單
DIGEST_RECIPIENTS=user1@example.com,user2@example.com

# === Error Monitoring ===
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# === Data Storage ===
DATA_DIR=/app/data
